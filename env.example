APP_ENV=development
LOG_LEVEL=INFO

# Market data
DATA_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=your_api_key_here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Scan configuration
FOREX_PAIRS=EUR/USD,GBP/USD,USD/JPY,AUD/USD,USD/CAD
TIMEFRAMES=15min,1h,4h
SCAN_INTERVAL_MINUTES=15
CANDLE_LIMIT=350
REQUEST_TIMEOUT_SECONDS=20

# Strategy
RISK_REWARD_RATIO=2.0
BREAKOUT_LOOKBACK=20
RSI_BUY_MAX=68
RSI_SELL_MIN=32
MIN_SIGNAL_SCORE=4
USE_BREAKOUT_FILTER=true

# Email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=timotejforex@outlook.com
SMTP_PASSWORD=64197712a
EMAIL_FROM=timotejforex@outlook.com
EMAIL_TO=timotejforex@outlook.com
EMAIL_ENABLED=true

# Storage
STATE_DIR=data
SIGNAL_STORE_FILE=sent_signals.json

# Runtime
SCHEDULER_TIMEZONE=UTC
